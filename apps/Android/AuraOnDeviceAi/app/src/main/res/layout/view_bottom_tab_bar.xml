<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="?colorSurface"
        android:elevation="4dp">

        <!-- Chat Tab -->
        <LinearLayout
            android:id="@+id/tab_chat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/icon_chat"
                android:layout_width="@dimen/bottom_tab_icon_size"
                android:layout_height="@dimen/bottom_tab_icon_size"
                android:layout_marginBottom="4dp"
                app:tint="@color/tab_text_selector"
                app:srcCompat="@drawable/ic_chat" />

            <TextView
                android:id="@+id/text_chat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_chat"
                android:textSize="12sp"
                android:textColor="@color/tab_text_selector"/>
        </LinearLayout>

        <!-- Model Market Tab -->
        <LinearLayout
            android:id="@+id/tab_model_market"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/icon_model_market"
                android:layout_width="@dimen/bottom_tab_icon_size"
                android:layout_height="@dimen/bottom_tab_icon_size"
                app:tint="@color/tab_text_selector"
                android:layout_marginBottom="4dp"
                android:src="@drawable/ic_model_list" />

            <TextView
                android:id="@+id/text_model_market"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/models_market"
                android:textSize="12sp"
                android:textColor="@color/tab_text_selector"/>
        </LinearLayout>

        <!-- AI Studio Tab -->
        <LinearLayout
            android:id="@+id/tab_ai_studio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            >

            <ImageView
                android:id="@+id/icon_ai_studio"
                android:layout_width="@dimen/bottom_tab_icon_size"
                android:layout_height="@dimen/bottom_tab_icon_size"
                android:layout_marginBottom="4dp"
                app:tint="@color/tab_text_selector"
                app:srcCompat="@drawable/ic_model" />

            <TextView
                android:id="@+id/text_ai_studio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_studio"
                android:textSize="12sp"
                android:textColor="@color/tab_text_selector"/>
        </LinearLayout>

    </LinearLayout>
</merge>
